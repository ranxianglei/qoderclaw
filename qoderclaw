#!/usr/bin/env python3
"""
QoderClaw 服务管理脚本

用法:
    ./qoderclaw start    启动服务
    ./qoderclaw stop     停止服务
    ./qoderclaw status   查看状态
    ./qoderclaw restart  重启服务
"""
import os
import sys
import signal
import subprocess
import time
from pathlib import Path

# 配置
SCRIPT_DIR = Path(__file__).parent.absolute()
PID_FILE = SCRIPT_DIR / "qoderclaw.pid"
LOG_FILE = SCRIPT_DIR / "logs" / "qoderclaw.log"
DEFAULT_HOST = "0.0.0.0"
DEFAULT_PORT = 8080


def get_pid():
    """读取 PID 文件"""
    if PID_FILE.exists():
        try:
            pid = int(PID_FILE.read_text().strip())
            # 检查进程是否存在
            os.kill(pid, 0)
            return pid
        except (ValueError, ProcessLookupError, PermissionError):
            PID_FILE.unlink(missing_ok=True)
    return None


def is_running():
    """检查服务是否运行"""
    return get_pid() is not None


def start(host=DEFAULT_HOST, port=DEFAULT_PORT):
    """启动服务"""
    if is_running():
        pid = get_pid()
        print(f"QoderClaw 已在运行 (PID: {pid})")
        return False
    
    print("正在启动 QoderClaw...")
    
    # 确保日志目录存在
    (SCRIPT_DIR / "logs").mkdir(exist_ok=True)
    
    # 启动进程
    venv_python = SCRIPT_DIR / "venv" / "bin" / "python"
    if not venv_python.exists():
        venv_python = sys.executable
    
    cmd = [str(venv_python), "main.py", "--host", host, "--port", str(port)]
    
    # 使用 nohup 后台运行
    process = subprocess.Popen(
        cmd,
        cwd=SCRIPT_DIR,
        stdout=open(LOG_FILE, "a"),
        stderr=subprocess.STDOUT,
        start_new_session=True,
    )
    
    # 写入 PID 文件
    PID_FILE.write_text(str(process.pid))
    
    # 等待启动
    time.sleep(2)
    
    # 检查是否启动成功
    if is_running():
        print(f"QoderClaw 启动成功 (PID: {process.pid})")
        print(f"API 文档: http://localhost:{port}/docs")
        return True
    else:
        print("QoderClaw 启动失败，请检查日志:")
        print(f"  tail -f {LOG_FILE}")
        return False


def stop():
    """停止服务"""
    pid = get_pid()
    if not pid:
        print("QoderClaw 未运行")
        return True
    
    print(f"正在停止 QoderClaw (PID: {pid})...")
    
    try:
        # 发送 SIGTERM
        os.kill(pid, signal.SIGTERM)
        
        # 等待进程结束
        for _ in range(10):
            time.sleep(0.5)
            try:
                os.kill(pid, 0)
            except ProcessLookupError:
                PID_FILE.unlink(missing_ok=True)
                print("QoderClaw 已停止")
                return True
        
        # 强制杀死
        print("进程未响应，强制停止...")
        os.kill(pid, signal.SIGKILL)
        time.sleep(0.5)
        PID_FILE.unlink(missing_ok=True)
        print("QoderClaw 已强制停止")
        return True
        
    except ProcessLookupError:
        PID_FILE.unlink(missing_ok=True)
        print("QoderClaw 进程已不存在")
        return True
    except Exception as e:
        print(f"停止失败: {e}")
        return False


def status():
    """查看状态"""
    pid = get_pid()
    if not pid:
        print("状态: 未运行")
        return
    
    print(f"状态: 运行中 (PID: {pid})")
    print(f"日志: {LOG_FILE}")
    
    # 调用健康检查 API
    try:
        import urllib.request
        import json
        
        with urllib.request.urlopen(f"http://localhost:{DEFAULT_PORT}/health", timeout=5) as resp:
            health = json.loads(resp.read().decode())
        
        print(f"\n健康状态: {health.get('status', 'unknown')}")
        
        # Qoder 实例
        instances = health.get("qoder_instances", {})
        if instances:
            print("\nQoder 实例:")
            for name, info in instances.items():
                print(f"  - {name}: {info.get('status', 'unknown')} (PID: {info.get('pid')}, 内存: {info.get('memory_mb', 0):.1f}MB)")
        
        # Bot 状态
        bots = health.get("bots", {})
        if bots:
            print("\n飞书机器人:")
            for bot_id, info in bots.items():
                print(f"  - {bot_id}: {info.get('status', 'unknown')}")
                
    except Exception as e:
        print(f"无法获取健康状态: {e}")


def restart():
    """重启服务"""
    print("正在重启 QoderClaw...")
    stop()
    time.sleep(1)
    return start()


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)
    
    command = sys.argv[1].lower()
    
    if command == "start":
        host = sys.argv[2] if len(sys.argv) > 2 else DEFAULT_HOST
        port = int(sys.argv[3]) if len(sys.argv) > 3 else DEFAULT_PORT
        success = start(host, port)
    elif command == "stop":
        success = stop()
    elif command == "status":
        status()
        success = True
    elif command == "restart":
        success = restart()
    else:
        print(f"未知命令: {command}")
        print(__doc__)
        sys.exit(1)
    
    sys.exit(0 if success else 1)


if __name__ == "__main__":
    main()
